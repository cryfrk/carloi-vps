{
  "name": "carloi",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "payment-proxy": "node payment-proxy/index.js",
    "validate:production": "node scripts/validate-production.js",
    "db:migrate:postgres": "node scripts/migrate-postgres.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "docker:build": "docker build -t carloi-api .",
    "docker:build:payment-proxy": "docker build -f payment-proxy/Dockerfile -t carloi-payment-proxy .",
    "build:apk": "npx eas-cli build -p android --profile apk",
    "build:apk-local": "cd android && set NODE_ENV=production&& gradlew.bat assembleRelease",
    "build:aab": "npx eas-cli build -p android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@google-cloud/storage": "^7.19.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-font": "~14.0.11",
    "expo-iap": "^4.1.0",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "^55.0.13",
    "expo-location": "^55.1.8",
    "expo-secure-store": "^55.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwk-to-pem": "^2.0.7",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "@prisma/client": "^6.17.1",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bluetooth-classic": "^1.73.0-rc.17",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-web": "^0.21.0",
    "react-native-wifi-reborn": "^4.13.6",
    "twilio": "^5.13.1",
    "with-rn-bluetooth-classic": "^1.0.5"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/react": "~19.1.0",
    "prisma": "^6.17.1",
    "recast": "^0.23.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
