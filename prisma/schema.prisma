generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  individual
  commercial
}

enum CommercialStatus {
  not_applied
  pending
  approved
  rejected
  suspended
  revoked
}

enum TaxOrIdentityType {
  VKN
  TCKN
}

enum CommercialProfileStatus {
  draft
  submitted
  pending_review
  approved
  rejected
  suspended
  revoked
}

enum CommercialDocumentType {
  tax_document
  authorization_certificate
  trade_registry
  identity_document
  other
}

enum CommercialDocumentStatus {
  uploaded
  pending_review
  approved
  rejected
  expired
}

enum VerificationMethod {
  manual_admin_review
  e_devlet_reference
  external_check
  unverified
}

enum SellerRelationType {
  owner
  spouse
  relative_second_degree
  authorized_business
  other_authorized
}

enum AuthorizationStatus {
  not_required
  declared
  pending_review
  approved
  rejected
}

enum EidsStatus {
  not_started
  declared
  pending
  verified_externally
  manual_review_required
  failed
}

enum ListingComplianceStatus {
  draft
  vehicle_info_completed
  pricing_completed
  ownership_completed
  compliance_completed
  payment_pending
  submitted
  restricted
  published
  suspended
  rejected
}

enum ListingBillingStatus {
  not_required
  pending
  paid
  failed
  waived
}

enum SaleProcessStatus {
  interest
  negotiating
  payment_guidance_shown
  ready_for_notary
  completed
  cancelled
}

enum UserSubscriptionStatus {
  inactive
  trial
  active
  past_due
  cancelled
}

enum PaymentProvider {
  garanti_virtual_pos
}

enum PaymentRecordType {
  subscription
  listing_fee
  featured_listing
  insurance_related
}

enum RiskLevel {
  low
  medium
  high
}

enum RiskFlagType {
  multiple_accounts
  duplicate_plate
  spam_listing
  abnormal_price
  suspicious_document
  excessive_sales
  message_abuse
  insurance_payment_risk
}

enum RiskSeverity {
  low
  medium
  high
}

enum RiskSource {
  system_rule
  admin
  user_report
}

enum RiskStatus {
  open
  reviewed
  dismissed
  confirmed
}

enum AuditActorType {
  user
  admin
  system
}

enum AdminRoleKey {
  super_admin
  compliance_admin
  moderation_admin
  support_admin
  billing_admin
  analytics_admin
  legal_export_admin
  ops_admin
}

enum UserConsentType {
  terms_of_service
  privacy_policy
  listing_responsibility
  content_responsibility
  commercial_declaration
  safe_payment_information
  subscription_terms
  marketing_optional
}

model User {
  id                          String                  @id
  name                        String
  handle                      String                  @unique
  bio                         String                  @default("")
  email                       String                  @unique
  phone                       String                  @unique
  passwordHash                String                  @map("password_hash")
  googleSub                   String?                 @map("google_sub")
  appleSub                    String?                 @map("apple_sub")
  verified                    Int                     @default(0)
  avatarUri                   String?                 @map("avatar_uri")
  coverUri                    String?                 @map("cover_uri")
  membershipPlan              String                  @default("Standart Uyelik") @map("membership_plan")
  settingsJson                String                  @map("settings_json")
  vehicleJson                 String?                 @map("vehicle_json")
  profileSegment              String                  @default("paylasimlar") @map("profile_segment")
  accountType                 AccountType             @default(individual) @map("account_type")
  commercialStatus            CommercialStatus        @default(not_applied) @map("commercial_status")
  commercialApprovedAt        DateTime?               @db.Timestamptz(6) @map("commercial_approved_at")
  commercialRejectedReason    String?                 @map("commercial_rejected_reason")
  commercialReviewedByAdminId String?                 @map("commercial_reviewed_by_admin_id")
  yearlyVehicleSaleCount      Int                     @default(0) @map("yearly_vehicle_sale_count")
  yearlyVehicleListingCount   Int                     @default(0) @map("yearly_vehicle_listing_count")
  commercialBehaviorFlag      Boolean                 @default(false) @map("commercial_behavior_flag")
  riskScore                   Int                     @default(0) @map("risk_score")
  riskLevel                   RiskLevel               @default(low) @map("risk_level")
  canCreatePaidListings       Boolean                 @default(false) @map("can_create_paid_listings")
  subscriptionStatus          UserSubscriptionStatus  @default(inactive) @map("subscription_status")
  subscriptionPlanId          String?                 @map("subscription_plan_id")
  forgotPasswordRequiredResetAt DateTime?             @db.Timestamptz(6) @map("forgot_password_required_reset_at")
  lastLoginIp                 String?                 @map("last_login_ip")
  lastKnownDeviceFingerprint  String?                 @map("last_known_device_fingerprint")
  fraudFlagCount              Int                     @default(0) @map("fraud_flag_count")
  createdAt                   DateTime                @db.Timestamptz(6) @map("created_at")
  updatedAt                   DateTime                @db.Timestamptz(6) @map("updated_at")

  sessions                    Session[]
  posts                       Post[]
  sentMessages                Message[]
  authTokens                  AuthToken[]
  commercialProfile           CommercialProfile?
  commercialDocuments         CommercialDocument[]
  subscriptions               UserSubscription[]
  paymentRecords              PaymentRecord[]
  auditLogs                   AuditLog[]              @relation("AuditActor")
  riskFlags                   RiskFlag[]
  consents                    UserConsent[]
  adminRoleAssignments        UserAdminRole[]
  yearlyActivity              UserYearlyActivity[]

  @@map("users")
}

model Session {
  token     String   @id
  userId    String   @map("user_id")
  createdAt DateTime @db.Timestamptz(6) @map("created_at")
  expiresAt DateTime @db.Timestamptz(6) @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Post {
  id             String              @id
  authorUserId   String              @map("author_user_id")
  type           String
  content        String
  hashtagsJson   String              @map("hashtags_json")
  mediaJson      String              @map("media_json")
  listingJson    String?             @map("listing_json")
  repostSourceId String?             @map("repost_source_id")
  createdAt      DateTime            @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime            @db.Timestamptz(6) @map("updated_at")

  author               User                @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  compliance           ListingCompliance?
  saleProcesses        SaleProcess[]       @relation("SaleProcessListing")
  paymentRecords       PaymentRecord[]     @relation("PaymentRecordListing")
  riskFlags            RiskFlag[]
  listingTransactions  ListingTransaction[]

  @@index([authorUserId, createdAt])
  @@index([repostSourceId])
  @@map("posts")
}

model Conversation {
  id              String               @id
  type            String
  name            String
  handle          String
  contextPostId   String?              @map("context_post_id")
  buyerUserId     String?              @map("buyer_user_id")
  sellerUserId    String?              @map("seller_user_id")
  buyerAgreedAt   DateTime?            @db.Timestamptz(6) @map("buyer_agreed_at")
  sellerAgreedAt  DateTime?            @db.Timestamptz(6) @map("seller_agreed_at")
  createdAt       DateTime             @db.Timestamptz(6) @map("created_at")

  messages            Message[]
  listingTransactions ListingTransaction[]

  @@map("conversations")
}

model Message {
  id                   String    @id
  conversationId       String    @map("conversation_id")
  senderUserId         String    @map("sender_user_id")
  text                 String
  attachmentsJson      String    @default("[]") @map("attachments_json")
  editedAt             DateTime? @db.Timestamptz(6) @map("edited_at")
  deletedForEveryoneAt DateTime? @db.Timestamptz(6) @map("deleted_for_everyone_at")
  createdAt            DateTime  @db.Timestamptz(6) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model AuthToken {
  id         String    @id
  userId     String    @map("user_id")
  type       String
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @db.Timestamptz(6) @map("expires_at")
  consumedAt DateTime? @db.Timestamptz(6) @map("consumed_at")
  createdAt  DateTime  @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, consumedAt])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model ListingTransaction {
  conversationId     String    @id @map("conversation_id")
  postId             String    @map("post_id")
  buyerUserId        String    @map("buyer_user_id")
  sellerUserId       String    @map("seller_user_id")
  registrationJson   String?   @map("registration_json")
  registrationSharedAt DateTime? @db.Timestamptz(6) @map("registration_shared_at")
  insuranceQuoteAmount String? @map("insurance_quote_amount")
  paymentStatus      String    @default("missing") @map("payment_status")
  paymentReference   String?   @map("payment_reference")
  paymentRequestedAt DateTime? @db.Timestamptz(6) @map("payment_requested_at")
  paymentPaidAt      DateTime? @db.Timestamptz(6) @map("payment_paid_at")
  policyUri          String?   @map("policy_uri")
  invoiceUri         String?   @map("invoice_uri")
  policySentAt       DateTime? @db.Timestamptz(6) @map("policy_sent_at")
  invoiceSentAt      DateTime? @db.Timestamptz(6) @map("invoice_sent_at")
  createdAt          DateTime  @db.Timestamptz(6) @map("created_at")
  updatedAt          DateTime  @db.Timestamptz(6) @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("listing_transactions")
}

model CommercialProfile {
  id                    String                  @id @default(cuid())
  userId                String                  @unique @map("user_id")
  companyName           String                  @map("company_name")
  taxOrIdentityType     TaxOrIdentityType       @map("tax_or_identity_type")
  taxOrIdentityNumber   String                  @map("tax_or_identity_number")
  tradeName             String?                 @map("trade_name")
  mersisNumber          String?                 @map("mersis_number")
  authorizedPersonName  String?                 @map("authorized_person_name")
  authorizedPersonTitle String?                 @map("authorized_person_title")
  phone                 String
  city                  String
  district              String
  address               String
  notes                 String?
  status                CommercialProfileStatus @default(draft)
  submittedAt           DateTime?               @db.Timestamptz(6) @map("submitted_at")
  documentTruthfulnessAcceptedAt DateTime?      @db.Timestamptz(6) @map("document_truthfulness_accepted_at")
  additionalVerificationAcknowledgedAt DateTime? @db.Timestamptz(6) @map("additional_verification_acknowledged_at")
  createdAt             DateTime                @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt             DateTime                @default(now()) @db.Timestamptz(6) @map("updated_at")

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents CommercialDocument[]

  @@index([status])
  @@index([taxOrIdentityNumber])
  @@map("commercial_profiles")
}

model CommercialDocument {
  id                 String                   @id @default(cuid())
  userId             String                   @map("user_id")
  commercialProfileId String                  @map("commercial_profile_id")
  type               CommercialDocumentType
  fileUrl            String                   @map("file_url")
  originalFileName   String                   @map("original_file_name")
  mimeType           String                   @map("mime_type")
  fileSize           BigInt                   @map("file_size")
  uploadedAt         DateTime                 @default(now()) @db.Timestamptz(6) @map("uploaded_at")
  status             CommercialDocumentStatus @default(uploaded)
  reviewedByAdminId  String?                  @map("reviewed_by_admin_id")
  reviewedAt         DateTime?                @db.Timestamptz(6) @map("reviewed_at")
  rejectReason       String?                  @map("reject_reason")
  verificationMethod VerificationMethod       @default(unverified) @map("verification_method")
  suspiciousFlag     Boolean                  @default(false) @map("suspicious_flag")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  commercialProfile CommercialProfile @relation(fields: [commercialProfileId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([commercialProfileId, type])
  @@map("commercial_documents")
}

model ListingCompliance {
  postId                           String                 @id @map("post_id")
  sellerRelationType               SellerRelationType?    @map("seller_relation_type")
  plateNumber                      String?                @map("plate_number")
  registrationOwnerFullNameDeclared String?               @map("registration_owner_full_name_declared")
  isOwnerSameAsAccountHolder       Boolean?               @map("is_owner_same_as_account_holder")
  authorizationDeclarationText     String?                @map("authorization_declaration_text")
  authorizationDeclarationAccepted Boolean                @default(false) @map("authorization_declaration_accepted")
  authorizationStatus              AuthorizationStatus    @default(not_required) @map("authorization_status")
  eidsStatus                       EidsStatus             @default(not_started) @map("eids_status")
  safePaymentInfoAccepted          Boolean                @default(false) @map("safe_payment_info_accepted")
  safePaymentInfoAcceptedAt        DateTime?              @db.Timestamptz(6) @map("safe_payment_info_accepted_at")
  listingComplianceStatus          ListingComplianceStatus @default(draft) @map("listing_compliance_status")
  riskScore                        Int                    @default(0) @map("risk_score")
  riskLevel                        RiskLevel              @default(low) @map("risk_level")
  billingRequired                  Boolean                @default(false) @map("billing_required")
  billingStatus                    ListingBillingStatus   @default(not_required) @map("billing_status")
  paymentRecordId                  String?                @map("payment_record_id")
  duplicatePlateFlag               Boolean                @default(false) @map("duplicate_plate_flag")
  abnormalPriceFlag                Boolean                @default(false) @map("abnormal_price_flag")
  spamContentFlag                  Boolean                @default(false) @map("spam_content_flag")
  reviewRequiredReason             String?                @map("review_required_reason")
  reviewedByAdminId                String?                @map("reviewed_by_admin_id")
  reviewedAt                       DateTime?              @db.Timestamptz(6) @map("reviewed_at")
  createdAt                        DateTime               @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                        DateTime               @default(now()) @db.Timestamptz(6) @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([listingComplianceStatus])
  @@index([plateNumber])
  @@index([riskLevel, billingStatus])
  @@map("listing_compliance")
}

model SaleProcess {
  id                      String            @id @default(cuid())
  listingId               String            @map("listing_id")
  buyerUserId             String            @map("buyer_user_id")
  sellerUserId            String            @map("seller_user_id")
  status                  SaleProcessStatus @default(interest)
  safePaymentReferenceCode String?          @map("safe_payment_reference_code")
  safePaymentProviderName String?           @map("safe_payment_provider_name")
  safePaymentStatusNote   String?           @map("safe_payment_status_note")
  safePaymentInfoAcceptedAt DateTime?       @db.Timestamptz(6) @map("safe_payment_info_accepted_at")
  createdAt               DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt               DateTime          @default(now()) @db.Timestamptz(6) @map("updated_at")

  listing Post @relation("SaleProcessListing", fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
  @@index([buyerUserId, sellerUserId])
  @@map("sale_processes")
}

model SubscriptionPlan {
  id                 String             @id @default(cuid())
  name               String
  code               String             @unique
  monthlyPrice       Decimal            @db.Decimal(12, 2) @map("monthly_price")
  yearlyPrice        Decimal?           @db.Decimal(12, 2) @map("yearly_price")
  currency           String             @default("TRY")
  maxListingsPerMonth Int               @default(0) @map("max_listings_per_month")
  maxFeaturedListings Int               @default(0) @map("max_featured_listings")
  isCommercialOnly   Boolean            @default(false) @map("is_commercial_only")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt          DateTime           @default(now()) @db.Timestamptz(6) @map("updated_at")

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id                       String                 @id @default(cuid())
  userId                   String                 @map("user_id")
  planId                   String                 @map("plan_id")
  status                   UserSubscriptionStatus @default(inactive)
  startAt                  DateTime?              @db.Timestamptz(6) @map("start_at")
  endAt                    DateTime?              @db.Timestamptz(6) @map("end_at")
  renewalAt                DateTime?              @db.Timestamptz(6) @map("renewal_at")
  paymentProvider          PaymentProvider?       @map("payment_provider")
  paymentStatus            String?                @map("payment_status")
  externalPaymentReference String?                @map("external_payment_reference")
  createdAt                DateTime               @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                DateTime               @default(now()) @db.Timestamptz(6) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([planId, status])
  @@map("user_subscriptions")
}

model BillingSettings {
    id                               String   @id @default("default")
    paidListingsEnabled              Boolean  @default(false) @map("paid_listings_enabled")
    subscriptionRequiredForCommercial Boolean @default(false) @map("subscription_required_for_commercial")
    individualListingFeeEnabled      Boolean  @default(false) @map("individual_listing_fee_enabled")
    featuredListingFeeEnabled        Boolean  @default(false) @map("featured_listing_fee_enabled")
    individualListingFeeAmount       Decimal  @default(0) @db.Decimal(12, 2) @map("individual_listing_fee_amount")
    featuredListingFeeAmount         Decimal  @default(0) @db.Decimal(12, 2) @map("featured_listing_fee_amount")
    currency                         String   @default("TRY")
    updatedAt                        DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

    @@map("billing_settings")
  }

model PaymentRecord {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  listingId   String?           @map("listing_id")
  type        PaymentRecordType
  amount      Decimal           @db.Decimal(12, 2)
  currency    String            @default("TRY")
  provider    String
  status      String
  externalRef String?           @map("external_ref")
  metadata    Json?             @db.JsonB
  createdAt   DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime          @default(now()) @db.Timestamptz(6) @map("updated_at")

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Post? @relation("PaymentRecordListing", fields: [listingId], references: [id], onDelete: SetNull)

  @@index([userId, type, status])
  @@index([listingId])
  @@map("payment_records")
}

model UserYearlyActivity {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  year              Int
  vehicleSaleCount  Int      @default(0) @map("vehicle_sale_count")
  vehicleListingCount Int    @default(0) @map("vehicle_listing_count")
  createdAt         DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([year])
  @@map("user_yearly_activity")
}

model AuditLog {
  id         String         @id @default(cuid())
  actorType  AuditActorType @map("actor_type")
  actorId    String?        @map("actor_id")
  targetType String         @map("target_type")
  targetId   String?        @map("target_id")
  action     String
  metadata   Json?          @db.JsonB
  ipAddress  String?        @map("ip_address")
  userAgent  String?        @map("user_agent")
  createdAt  DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorType, actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model RiskFlag {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  relatedListingId String?      @map("related_listing_id")
  type             RiskFlagType
  severity         RiskSeverity
  source           RiskSource
  status           RiskStatus   @default(open)
  notes            String?
  createdAt        DateTime     @default(now()) @db.Timestamptz(6) @map("created_at")
  reviewedAt       DateTime?    @db.Timestamptz(6) @map("reviewed_at")
  reviewedByAdminId String?     @map("reviewed_by_admin_id")

  user           User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedListing Post? @relation(fields: [relatedListingId], references: [id], onDelete: SetNull)

  @@index([userId, status, severity])
  @@index([relatedListingId, status])
  @@index([type, status, createdAt])
  @@map("risk_flags")
}

model UserConsent {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  consentType UserConsentType @map("consent_type")
  version     String
  acceptedAt  DateTime        @default(now()) @db.Timestamptz(6) @map("accepted_at")
  sourceScreen String         @map("source_screen")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentType, version])
  @@index([userId, acceptedAt])
  @@map("user_consents")
}

model PlatformFeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  rolloutJson Json?    @db.JsonB @map("rollout_json")
  updatedAt   DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  @@map("platform_feature_flags")
}

model AdminRole {
  key         AdminRoleKey   @id
  label       String
  description String
  createdAt   DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime       @default(now()) @db.Timestamptz(6) @map("updated_at")

  assignments UserAdminRole[]

  @@map("admin_roles")
}

model UserAdminRole {
  id               String       @id @default(cuid())
  userId           String       @map("user_id")
  roleKey          AdminRoleKey @map("role_key")
  grantedByAdminId String?      @map("granted_by_admin_id")
  grantedAt        DateTime     @default(now()) @db.Timestamptz(6) @map("granted_at")
  revokedAt        DateTime?    @db.Timestamptz(6) @map("revoked_at")
  notes            String?

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AdminRole @relation(fields: [roleKey], references: [key], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([roleKey, revokedAt])
  @@map("user_admin_roles")
}
