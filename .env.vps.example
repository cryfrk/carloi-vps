NODE_ENV=development
HOST=0.0.0.0
PORT=8080
API_PORT=8080
AUTO_MIGRATE_POSTGRES=true

POSTGRES_DB=carloi
POSTGRES_USER=carloi_user
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://carloi_user:change-this-postgres-password@postgres:5432/carloi
DATABASE_SSL=false
VCARX_ALLOW_INMEMORY_FALLBACK=false

# VPS smoke test icin development + validation bypass kullanilir.
# Gercek domain ve TLS hazir oldugunda bunlari production degerlerine cekin.
VCARX_SKIP_VALIDATION=true
VCARX_REQUIRE_HTTPS=false
VCARX_TRUST_PROXY=false

VCARX_CORS_ORIGIN=http://localhost:3000
VCARX_PUBLIC_BASE_URL=http://localhost:8080
APP_BASE_URL=http://localhost:3000
VCARX_SHARE_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_SHARE_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SHARE_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Carloi
NEXT_PUBLIC_SUPPORT_EMAIL=destek@carloi.local
NEXT_PUBLIC_PRIVACY_URL=http://localhost:3000/gizlilik
NEXT_PUBLIC_TERMS_URL=http://localhost:3000/kullanici-sozlesmesi

STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads
UPLOADS_BASE_PATH=/uploads
UPLOADS_PREFIX=media
UPLOADS_PUBLIC_BASE_URL=

VCARX_SESSION_TTL_DAYS=30
VCARX_SESSION_SECRET=change-this-session-secret-for-vps
VCARX_DATA_ENCRYPTION_SECRET=change-this-data-encryption-secret-for-vps
VCARX_LOOKUP_SECRET=change-this-lookup-secret-for-vps
VCARX_ADMIN_TOKEN=change-this-admin-token-for-vps
VCARX_ENABLE_LEGACY_ADMIN_TOKEN_IN_PRODUCTION=false

VCARX_DISABLE_EMAIL=true
SMTP_DISABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Carloi <info@carloi.local>"
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_ENABLE_LEGACY_TLS_IN_PRODUCTION=false
SMTP_TLS_SERVERNAME=
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_GREETING_TIMEOUT_MS=5000
SMTP_SOCKET_TIMEOUT_MS=8000
SMTP_OPERATION_TIMEOUT_MS=6000

PG_CONNECTION_TIMEOUT_MS=10000
PG_QUERY_TIMEOUT_MS=12000
PG_STATEMENT_TIMEOUT_MS=12000

FEATURE_ENABLE_COMMERCIAL_ONBOARDING=false
FEATURE_ENABLE_COMMERCIAL_APPROVAL_GATE=false
FEATURE_ENABLE_LISTING_COMPLIANCE_STEP=false
FEATURE_ENABLE_SAFE_PAYMENT_GUIDANCE=false
FEATURE_ENABLE_RISK_DETECTION=false
FEATURE_ENABLE_PAID_LISTINGS=false
FEATURE_ENABLE_SUBSCRIPTIONS=false
FEATURE_ENABLE_ADMIN_EVIDENCE_EXPORTS=false

# Payment proxy ayri servis/container ise bu URL'leri sonradan doldurun.
VCARX_PAYMENT_PROXY_URL=
VCARX_BILLING_PAYMENT_PROXY_URL=
VCARX_PAYMENT_PROXY_PUBLIC_BASE_URL=
VCARX_PAYMENT_PAGE_BASE_URL=http://localhost:3000
VCARX_PAYMENT_RETURN_SCHEME=carloi://payment-result
VCARX_PAYMENT_CALLBACK_TOKEN=
VCARX_PAYMENT_CALLBACK_SIGNATURE_SECRET=
VCARX_PAYMENT_CALLBACK_SIGNATURE_HEADER=x-payment-signature
VCARX_PAYMENT_CALLBACK_MAX_AGE_SECONDS=900
VCARX_PAYMENT_MAX_RETRY_COUNT=3
VCARX_PLATFORM_PAYMENT_CALLBACK_URL=

GARANTI_MODE=TEST
GARANTI_API_VERSION=v0.01
GARANTI_SECURE3D_MODEL=3D_OOS_PAY
GARANTI_MERCHANT_ID=
GARANTI_TERMINAL_ID=
GARANTI_TERMINAL_PROV_USER_ID=PROVOOS
GARANTI_TERMINAL_USER_ID=PROVOOS
GARANTI_PROVISION_PASSWORD=
GARANTI_STORE_KEY=
GARANTI_GATE3DENGINE_URL=https://sanalposprovtest.garanti.com.tr/servlet/gt3dengine
GARANTI_VPSERVLET_URL=https://sanalposprovtest.garanti.com.tr/VPServlet
GARANTI_COMPANY_NAME=Carloi
GARANTI_LANGUAGE=tr

EXPO_PUBLIC_PREMIUM_MONTHLY_PRODUCT_ID=com.carloi.premium.monthly
EXPO_PUBLIC_PREMIUM_YEARLY_PRODUCT_ID=com.carloi.premium.yearly
VCARX_GOOGLE_PLAY_PACKAGE_NAME=com.carloi.mobile
VCARX_GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
VCARX_GOOGLE_PLAY_PRIVATE_KEY=
VCARX_APP_STORE_ISSUER_ID=
VCARX_APP_STORE_KEY_ID=
VCARX_APP_STORE_PRIVATE_KEY=
VCARX_APP_STORE_BUNDLE_ID=com.carloi.mobile
VCARX_APP_STORE_ENVIRONMENT=auto

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
EXPO_PUBLIC_DEEPSEEK_API_KEY=
EXPO_PUBLIC_DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_MODEL=gpt-5
AI_PROVIDER=
AI_API_KEY=

VCARX_TWILIO_ACCOUNT_SID=
VCARX_TWILIO_AUTH_TOKEN=
VCARX_TWILIO_FROM=
