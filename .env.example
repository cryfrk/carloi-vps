NODE_ENV=production
HOST=0.0.0.0
PORT=8080
API_PORT=8080
AUTO_MIGRATE_POSTGRES=true

VCARX_CORS_ORIGIN=https://www.carloi.com
VCARX_PUBLIC_BASE_URL=https://api.carloi.com
APP_BASE_URL=https://www.carloi.com
VCARX_SHARE_BASE_URL=https://www.carloi.com
EXPO_PUBLIC_API_BASE_URL=https://api.carloi.com
EXPO_PUBLIC_SHARE_BASE_URL=https://www.carloi.com
NEXT_PUBLIC_API_BASE_URL=https://api.carloi.com
NEXT_PUBLIC_SHARE_BASE_URL=https://www.carloi.com
NEXT_PUBLIC_APP_NAME=Carloi
NEXT_PUBLIC_SUPPORT_EMAIL=info@carloi.com
NEXT_PUBLIC_PRIVACY_URL=https://www.carloi.com/gizlilik
NEXT_PUBLIC_TERMS_URL=https://www.carloi.com/kullanici-sozlesmesi

DATABASE_URL=postgresql://carloi_user:strong_password@postgres:5432/carloi
DATABASE_SSL=false
VCARX_ALLOW_INMEMORY_FALLBACK=false
PG_CONNECTION_TIMEOUT_MS=10000
PG_QUERY_TIMEOUT_MS=12000
PG_STATEMENT_TIMEOUT_MS=12000

STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads
UPLOADS_BASE_PATH=/uploads
UPLOADS_PREFIX=media
UPLOADS_PUBLIC_BASE_URL=

VCARX_SESSION_TTL_DAYS=30
VCARX_SESSION_SECRET=change-this-secret
VCARX_DATA_ENCRYPTION_SECRET=change-this-data-encryption-secret
VCARX_LOOKUP_SECRET=change-this-lookup-secret
VCARX_SKIP_VALIDATION=false
VCARX_REQUIRE_HTTPS=true
VCARX_TRUST_PROXY=true
VCARX_ADMIN_TOKEN=
VCARX_ENABLE_LEGACY_ADMIN_TOKEN_IN_PRODUCTION=false

FEATURE_ENABLE_COMMERCIAL_ONBOARDING=false
FEATURE_ENABLE_COMMERCIAL_APPROVAL_GATE=false
FEATURE_ENABLE_LISTING_COMPLIANCE_STEP=false
FEATURE_ENABLE_SAFE_PAYMENT_GUIDANCE=false
FEATURE_ENABLE_RISK_DETECTION=false
FEATURE_ENABLE_PAID_LISTINGS=false
FEATURE_ENABLE_SUBSCRIPTIONS=false
FEATURE_ENABLE_ADMIN_EVIDENCE_EXPORTS=false

VCARX_PAYMENT_PROXY_URL=
VCARX_BILLING_PAYMENT_PROXY_URL=
VCARX_PAYMENT_PROXY_PORT=4100
VCARX_PAYMENT_PROVIDER=garanti_oos
VCARX_PAYMENT_PROXY_PUBLIC_BASE_URL=https://pay-proxy.carloi.com
VCARX_PAYMENT_PAGE_BASE_URL=https://www.carloi.com
VCARX_PAYMENT_RETURN_SCHEME=carloi://payment-result
VCARX_PAYMENT_CALLBACK_TOKEN=
VCARX_PAYMENT_CALLBACK_SIGNATURE_SECRET=
VCARX_PAYMENT_CALLBACK_SIGNATURE_HEADER=x-payment-signature
VCARX_PAYMENT_CALLBACK_MAX_AGE_SECONDS=900
VCARX_PAYMENT_MAX_RETRY_COUNT=3
VCARX_PLATFORM_PAYMENT_CALLBACK_URL=https://api.carloi.com/api/billing/garanti/callback

GARANTI_MODE=TEST
GARANTI_API_VERSION=v0.01
GARANTI_SECURE3D_MODEL=3D_OOS_PAY
GARANTI_MERCHANT_ID=
GARANTI_TERMINAL_ID=
